# Copy to .env and fill with REAL values. .env is git-ignored — never commit it.
# This file ships placeholders only. No real secret ever belongs here.
# Every key below maps 1:1 to a getter in lib/env.ts (the only reader of process.env).

# --- App ---
# Public site origin — drives canonical, Open Graph, sitemap, robots, and schema
# URLs (lib/env.baseUrl → lib/seo.absoluteUrl). No trailing slash. The CANONICAL
# production host is the apex misslanatheatre.com (Theatre spelling). Dev defaults
# to localhost; set the REAL canonical origin at deploy:
#   APP_BASE_URL=https://misslanatheatre.com
APP_BASE_URL=http://localhost:3000

# --- SEO (optional) ---
# Google Search Console verification token → <meta name="google-site-verification">.
GOOGLE_SITE_VERIFICATION=
# Google Maps Platform key (maps / service-area — planned; optional, unused until wired).
GOOGLE_MAPS_API_KEY=

# --- Lead pipeline (booking inquiries) ---
# MongoDB Atlas connection string — the DURABLE PRODUCTION STORE (system of record).
# Dedicated Miss Lana cluster ONLY — never reuse another project's DB/user/URI. The
# app uses database "misslana", collection "leads". SECRET, server-only: never commit
# a real value, never log it. When UNSET (local dev / e2e), the pipeline falls back to
# a real local-disk copy in LEAD_STORE_DIR; production always sets this.
#   MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority
MONGODB_URI=__REPLACE_ME__
# Owner notification destination. Defaults to info@misslanatheatre.com if unset.
LEAD_NOTIFY_EMAIL=info@misslanatheatre.com
# Transactional-email webhook (provider-agnostic). A POST {to, subject, text} sends
# the owner email. Use Resend/Postmark/SES-relay/a serverless fn. If unset, email
# delivery is "not configured" (durable store + optional Telegram still record it).
LEAD_EMAIL_WEBHOOK_URL=__REPLACE_ME__
LEAD_EMAIL_WEBHOOK_TOKEN=__REPLACE_ME__
# DEV-ONLY local lead copy dir (git-ignored). Used ONLY when MONGODB_URI is unset
# (local dev / e2e) — never the production authority. Default: .leads
LEAD_STORE_DIR=.leads
# Optional: trusted header to read the client IP from for rate-limiting (platform/edge
# specific). When unset, the limiter uses the last X-Forwarded-For entry. See SECURITY.md.
LEAD_TRUSTED_IP_HEADER=
# Optional: max booking submissions per IP per 60 s (default 5 in production). Raise
# ONLY in the e2e harness (shared localhost IP) — never in a real deployment.
LEAD_RATE_LIMIT_PER_MINUTE=

# --- Notifications (optional secondary alert) ---
# If both are set, a FULL Telegram alert (every field the visitor filled) is sent in
# addition to email — so the owner can act from the chat without DB access. Sent only to
# the owner's private bot/chat. Never an acceptance signal.
TELEGRAM_BOT_TOKEN=__REPLACE_ME__
TELEGRAM_CHAT_ID=__REPLACE_ME__

# --- Google Sheets (optional secondary cloud record) ---
# If set, each lead is appended as one row to a PRIVATE Google Sheet — a browsable cloud
# log for the owner (no DB access needed). Setup: a deployed Google Apps Script Web App
# that accepts POST {token, lead}, dedupes by submissionId under a lock, and answers with
# a small JSON contract (see LEAD_PIPELINE_RUNBOOK.md for the hardened script + the frozen
# column order). Never an acceptance signal. The token MUST equal the script's
# WEBHOOK_SECRET Script Property so only our app can append (never hard-code it in the
# script). Required whenever the URL is set.
GOOGLE_SHEETS_WEBHOOK_URL=__REPLACE_ME__
GOOGLE_SHEETS_WEBHOOK_TOKEN=__REPLACE_ME__
